{
  "name": "mambacode.js",
  "version": "1.0.0",
  "description": "High-performance TypeScript/WGSL Mamba SSM library for browser-based code model training and inference",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mamba", "ssm", "state-space-model", "webgpu", "wgsl", "machine-learning", "code-model", "bpe", "transformer-alternative", "typescript"],
  "author": {
    "name": "Sean Hogg",
    "email": "seanhogg@gmail.com",
    "url": "https://builderforce.ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeanHogg/Mamba.git"
  },
  "bugs": {
    "url": "https://github.com/SeanHogg/Mamba/issues"
  },
  "homepage": "https://github.com/SeanHogg/Mamba#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@webgpu/types": "^0.1.49",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ES2022",
            "moduleResolution": "bundler",
            "strict": true,
            "esModuleInterop": true,
            "skipLibCheck": true,
            "types": ["@webgpu/types", "jest"]
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
